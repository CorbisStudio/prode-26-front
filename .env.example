# =============================================================================
# World Cup Prode - Environment Configuration
# =============================================================================

# Application port (default: 4200)
FRONTEND_PORT=4200

# Docker image tag (default: latest)
IMAGE_TAG=latest

# Docker Hub / AWS ECR credentials (optional, for make push)
# DOCKER_USER=your-dockerhub-username

# AWS Configuration (optional, for make aws-push)
# AWS_REGION=us-east-1
# AWS_ACCOUNT_ID=123456789012

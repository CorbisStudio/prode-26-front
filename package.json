{
  "name": "world-cup-prode",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:es": "ng serve --configuration=es",
    "start:en": "ng serve --configuration=en",
    "build": "ng build",
    "build:es": "ng build --localize=es",
    "build:en": "ng build --localize=en",
    "watch": "ng build --watch --configuration development",
    "extract-i18n": "ng extract-i18n",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "ng lint",
    "format": "prettier --write ."
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^20.3.24",
    "@angular/compiler": "^20.3.24",
    "@angular/core": "^20.3.25",
    "@angular/forms": "^20.3.24",
    "@angular/platform-browser": "^20.3.24",
    "@angular/platform-browser-dynamic": "^20.3.24",
    "@angular/router": "^20.3.24",
    "@lucide/angular": "^1.17.0",
    "canvas-confetti": "^1.9.4",
    "date-fns": "^4.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "lmdb",
      "msgpackr-extract"
    ]
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^1.14.1",
    "@analogjs/vitest-angular": "^1.14.1",
    "@angular-devkit/build-angular": "^20.3.25",
    "@angular/cli": "^20.3.25",
    "@angular/compiler-cli": "^20.3.24",
    "@angular/localize": "^20.3.25",
    "@eslint/js": "^9.23.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/canvas-confetti": "^1.9.0",
    "angular-eslint": "^19.3.0",
    "eslint": "^9.23.0",
    "globals": "^16.0.0",
    "jiti": "^2.4.2",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.15",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.1.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.29.0",
    "vitest": "^3.1.1"
  }
}
